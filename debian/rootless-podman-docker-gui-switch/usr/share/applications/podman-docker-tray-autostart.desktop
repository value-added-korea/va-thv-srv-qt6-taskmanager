[Desktop Entry]
Name=VA Tray Podman & Docker Switcher
Comment=System tray widget for toggling rootless Podman and Docker
Exec=la_toolhive_thv_ui_tray
Icon=/usr/share/va/podman_utils/icons/both_active.ico
Terminal=false
Type=Application
Categories=System;Utility;
X-GNOME-Autostart-enabled=true
X-KDE-autostart-after=panel
